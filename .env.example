# ============================================================
# Greenfuel Asset Management — Environment Variables
# Copy this file to .env.local and fill in the values.
# ============================================================

# --- Database (MySQL) ---
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=greenfuel_assets

# --- Authentication ---
# Generate a strong random secret: openssl rand -base64 32
JWT_SECRET=change_me_to_a_long_random_string

# --- Email (SMTP) ---
# Configure your SMTP provider (e.g. Gmail, SendGrid, Mailgun, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_smtp_app_password
SMTP_FROM="Greenfuel Asset Management" <noreply@greenfuelenergy.in>

# --- Application ---
# Base URL used in invitation / password-reset emails
APP_URL=http://localhost:5000
